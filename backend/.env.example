# ─── MedAssist 360 · Backend Environment ───────────────────────────────────
# Copy this file to .env and fill in your real values.

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JS origins: http://localhost:5173, http://localhost:57704
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config). Switch to postgres+asyncpg://... for production.
DATABASE_URL=sqlite:///./medassist.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:57704,http://localhost:3000
